<div class="container py-4" style="max-width: 520px;">

  <h1 class="fw-bold mb-2">Invite a member</h1>
  <p class="text-muted mb-4">
    They'll get an email with a link to join <strong><%= current_workspace.name %></strong>.
  </p>

  <%= form_with model: @invitation, url: workspace_invitations_path, local: true do |form| %>
    <% if @invitation.errors.any? %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% @invitation.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-3">
      <%= form.label :email, class: "form-label fw-semibold" %>
      <%= form.email_field :email,
                           class: "form-control form-control-lg",
                           required: true,
                           autofocus: true,
                           placeholder: "teammate@example.com" %>
    </div>

    <div class="mb-4">
      <%= form.label :role, "Role", class: "form-label fw-semibold" %>
      <%= form.select :role,
                      [
                        [ "Viewer — read-only access",                          "viewer" ],
                        [ "Member — can create and edit folders + files",       "member" ],
                        [ "Admin — can also invite, promote, and manage settings", "admin" ]
                      ],
                      { selected: @invitation.role || "member" },
                      { class: "form-select form-select-lg" } %>
      <div class="form-text">
        You can change a member's role any time from the workspace settings page.
      </div>
    </div>

    <div class="d-flex gap-2">
      <%= form.submit "Send invitation", class: "btn btn-primary" %>
      <%= link_to "Cancel", workspace_path, class: "btn btn-link text-muted" %>
    </div>
  <% end %>

</div>
