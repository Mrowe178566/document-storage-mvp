<!-- Hero Section -->
<div class="fv-hero">
  <div class="fv-hero-inner">
    <div class="fv-hero-text">
      <div class="fv-hero-badge fade-in-up">A shared vault for your team</div>
      <h1 class="fv-hero-title fade-in-up">
        A simple, secure home for your team's files
      </h1>
      <p class="fv-hero-subtitle fade-in-up" style="animation-delay: 0.15s;">
        File Vault is a multi-tenant document storage app. Sign up, invite your teammates, and organize files into shared folders — with workspace-level access control built in.
      </p>
      <div class="d-flex gap-3 fade-in-up" style="animation-delay: 0.3s;">
        <%= link_to "Get Started Free", new_user_registration_path, class: "fv-btn-primary" %>
        <%= link_to "Sign In", new_user_session_path, class: "fv-btn-ghost" %>
      </div>
    </div>
    <div class="fv-hero-visual fade-in-up" style="animation-delay: 0.45s;">
      <div class="fv-hero-card">
        <div class="fv-hero-card-header">
          <i class="bi bi-folder-fill" style="color: #a78bfa; font-size: 1.25rem;"></i>
          <span>Important Documents</span>
        </div>
        <div class="fv-hero-card-item">
          <i class="bi bi-file-earmark-pdf" style="color: #f87171;"></i>
          <span>lease_agreement.pdf</span>
        </div>
        <div class="fv-hero-card-item">
          <i class="bi bi-file-earmark-word" style="color: #60a5fa;"></i>
          <span>resume_2026.docx</span>
        </div>
        <div class="fv-hero-card-item">
          <i class="bi bi-file-earmark-excel" style="color: #34d399;"></i>
          <span>budget_tracker.xlsx</span>
        </div>
        <div class="fv-hero-card-item fv-hero-card-item--muted">
          <i class="bi bi-clock"></i>
          <span>Updated 2 minutes ago</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Features Section -->
<div class="fv-features">
  <div class="fv-features-inner">
    <div class="text-center mb-5">
      <h2 class="fv-section-title">A simple, secure place for your team's documents</h2>
      <p class="fv-section-subtitle">Sign up, invite your team, and organize files into shared folders.</p>
    </div>
    <div class="fv-feature-grid">
      <div class="fv-feature-card">
        <div class="fv-feature-icon">
          <i class="bi bi-shield-lock"></i>
        </div>
        <h3>Workspace isolation</h3>
        <p>Every folder and file lives inside a workspace, and every query is scoped to the signed-in user's workspace. One team's files are never visible to another.</p>
      </div>
      <div class="fv-feature-card">
        <div class="fv-feature-icon">
          <i class="bi bi-people"></i>
        </div>
        <h3>Team invitations</h3>
        <p>Admins can invite teammates by email. Invitees set their own password to join the workspace. Two roles: admin (manages members) and member (manages files).</p>
      </div>
      <div class="fv-feature-card">
        <div class="fv-feature-icon">
          <i class="bi bi-folder2-open"></i>
        </div>
        <h3>Shared folders</h3>
        <p>Create folders that every member of the workspace can see and edit. Bulk-delete keeps cleanup fast.</p>
      </div>
      <div class="fv-feature-card">
        <div class="fv-feature-icon">
          <i class="bi bi-cloud-upload"></i>
        </div>
        <h3>Cloud-backed storage</h3>
        <p>Files are stored on Cloudinary via Active Storage. PDFs, images, common Office documents up to 25 MB.</p>
      </div>
    </div>
  </div>
</div>

<!-- CTA Section -->
<div class="fv-cta">
  <div class="fv-cta-inner">
    <h2>Ready to get your documents under control?</h2>
    <p>Create an account in under a minute and start uploading.</p>
    <%= link_to "Get Started Free", new_user_registration_path, class: "fv-btn-primary" %>
  </div>
</div>

