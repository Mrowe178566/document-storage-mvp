<div class="container py-5">
  <div class="row align-items-center justify-content-between">
    <%# Remember that bootstrap grid system is based on a 12-column layout and you want the text and image to take up the same amount of space %>
    <!-- LEFT SIDE TEXT -->
    <div class="col-md-6 mb-5 mb-md-0">
      <h1 class="display-4 fw-bold mb-3 fade-in-up">
        Organize Your Files With Ease
      </h1>

      <p class="lead mb-4 fade-in-up" style="animation-delay: 0.15s;">
        File Vault helps you securely store, organize, and access your files from anywhere.
        Simple. Fast. Reliable.
      </p>

      <div class="d-flex gap-3 fade-in-up" style="animation-delay: 0.3s;">
        <%= link_to "Get Started", new_user_registration_path, class: "btn btn-primary btn-lg px-4" %>
        <%= link_to "Sign In", new_user_session_path, class: "btn btn-outline-secondary btn-lg px-4" %>
      </div>
    </div>

    <!-- RIGHT SIDE LOGO -->
    <%# Here is a case where I lot of different CSS rules are being applied at once and it causes clear conflicts on mobile devices %>
    <div class="col-md-6 text-center fade-in-up" style="animation-delay: 0.45s;">
      <%# case and point the max-width makes it jarring on thinner phones and shows a background color change that is the complete opposite of what is intended %>
      <%= image_tag "vault-logo.png",
          alt: "File Vault Logo",
          class: "img-fluid" %>
    </div>

  </div>
</div>

<!-- Social Proof Section -->
<div class="container py-5">

  <!-- Section Header -->
  <div class="text-center mb-5">
    <h3 class="fw-bold mb-3">Trusted by teams who need secure, simple file storage</h3>
    <p class="text-muted">Real people. Real workflows. Real results.</p>
  </div>

  <div class="row g-4">

    <!-- Testimonial 1 -->
    <div class="col-md-4">
      <div class="card shadow-sm p-4 h-100">
        <p class="mb-3">“File Vault helped us organize years of documents in one afternoon. The interface is clean and intuitive.”</p>
        <div class="fw-bold">Operations Manager</div>
        <div class="text-muted small">Midwest Manufacturing Co.</div>
      </div>
    </div>

    <!-- Testimonial 2 -->
    <div class="col-md-4">
      <div class="card shadow-sm p-4 h-100">
        <p class="mb-3">“Our team finally has a secure place to store and share files without the complexity of enterprise tools.”</p>
        <div class="fw-bold">IT Coordinator</div>
        <div class="text-muted small">Logistics & Supply Chain</div>
      </div>
    </div>

    <!-- Testimonial 3 -->
    <div class="col-md-4">
      <div class="card shadow-sm p-4 h-100">
        <p class="mb-3">“Simple, fast, and reliable. File Vault fits perfectly into our daily workflow.”</p>
        <div class="fw-bold">Project Lead</div>
        <div class="text-muted small">Local Services Firm</div>
      </div>
    </div>

  </div>

  <!-- Trusted By Logos -->
  <div class="text-center mt-5">
    <p class="text-muted mb-3">Trusted by teams across industries</p>
    <div class="d-flex justify-content-center gap-4 flex-wrap opacity-75">
      <span class="fw-semibold">Acme Corp</span>
      <span class="fw-semibold">Northline Logistics</span>
      <span class="fw-semibold">Midwest Fabrication</span>
      <span class="fw-semibold">BrightPath Services</span>
    </div>
  </div>

</div>
