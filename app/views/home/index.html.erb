<!-- Hero Section -->
<div class="fv-hero">
  <div class="fv-hero-inner">
    <div class="fv-hero-text">
      <div class="fv-hero-badge fade-in-up">Built for manufacturing teams</div>
      <h1 class="fv-hero-title fade-in-up">
        Document control for the shop floor
      </h1>
      <p class="fv-hero-subtitle fade-in-up" style="animation-delay: 0.15s;">
        File Vault gives small manufacturing teams a secure, simple place to store SOPs, maintenance logs, compliance docs and more — no IT team required.
      </p>
      <div class="d-flex gap-3 fade-in-up" style="animation-delay: 0.3s;">
        <%= link_to "Get Started Free", new_user_registration_path, class: "fv-btn-primary" %>
        <%= link_to "Sign In", new_user_session_path, class: "fv-btn-ghost" %>
      </div>
    </div>
    <div class="fv-hero-visual fade-in-up" style="animation-delay: 0.45s;">
      <div class="fv-hero-card">
        <div class="fv-hero-card-header">
          <i class="bi bi-folder-fill" style="color: #a78bfa; font-size: 1.25rem;"></i>
          <span>SOPs & Work Instructions</span>
        </div>
        <div class="fv-hero-card-item">
          <i class="bi bi-file-earmark-pdf" style="color: #f87171;"></i>
          <span>machine_maintenance_SOP.pdf</span>
        </div>
        <div class="fv-hero-card-item">
          <i class="bi bi-file-earmark-word" style="color: #60a5fa;"></i>
          <span>quality_checklist_v3.docx</span>
        </div>
        <div class="fv-hero-card-item">
          <i class="bi bi-file-earmark-excel" style="color: #34d399;"></i>
          <span>inventory_log_2026.xlsx</span>
        </div>
        <div class="fv-hero-card-item fv-hero-card-item--muted">
          <i class="bi bi-clock"></i>
          <span>Updated 2 minutes ago</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Features Section -->
<div class="fv-features">
  <div class="fv-features-inner">
    <div class="text-center mb-5">
      <h2 class="fv-section-title">Everything your team needs</h2>
      <p class="fv-section-subtitle">Designed for small manufacturing teams with no IT support</p>
    </div>
    <div class="fv-feature-grid">
      <div class="fv-feature-card">
        <div class="fv-feature-icon">
          <i class="bi bi-shield-lock"></i>
        </div>
        <h3>Secure by default</h3>
        <p>Every user only sees their own documents. No accidental sharing, no data leaks.</p>
      </div>
      <div class="fv-feature-card">
        <div class="fv-feature-icon">
          <i class="bi bi-camera"></i>
        </div>
        <h3>Scan & upload</h3>
        <p>Photograph paper documents on the shop floor and upload them instantly from any device.</p>
      </div>
      <div class="fv-feature-card">
        <div class="fv-feature-icon">
          <i class="bi bi-robot"></i>
        </div>
        <h3>AI-powered search</h3>
        <p>Find any document using plain language. Ask "maintenance log for press 4" and get it instantly.</p>
      </div>
      <div class="fv-feature-card">
        <div class="fv-feature-icon">
          <i class="bi bi-people"></i>
        </div>
        <h3>Team workspaces</h3>
        <p>Invite your team, set permissions, and keep every department's files organized separately.</p>
      </div>
      <div class="fv-feature-card">
        <div class="fv-feature-icon">
          <i class="bi bi-check2-circle"></i>
        </div>
        <h3>Document approvals</h3>
        <p>Route documents for sign-off before they go live. Full audit trail included.</p>
      </div>
      <div class="fv-feature-card">
        <div class="fv-feature-icon">
          <i class="bi bi-cloud-upload"></i>
        </div>
        <h3>Cloud storage</h3>
        <p>Files stored securely in the cloud via Cloudinary. Access from anywhere, any device.</p>
      </div>
    </div>
  </div>
</div>

