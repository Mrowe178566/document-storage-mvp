<% if user_signed_in? %>
  <nav class="fv-sidebar" role="navigation" aria-label="Main navigation">

    <%# ─── Workspace switcher header ─────────────────────────── %>
    <% if current_workspace %>
      <div class="fv-sidebar-workspace dropend">
        <button class="fv-workspace-trigger"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false">
          <div class="fv-workspace-badge">
            <%= current_workspace.name.first.upcase %>
          </div>
          <div class="fv-workspace-meta">
            <div class="fv-workspace-name"><%= current_workspace.name %></div>
            <div class="fv-workspace-role">
              <%= current_membership&.role&.capitalize || "Member" %>
            </div>
          </div>
          <i class="bi bi-chevron-expand fv-workspace-caret"></i>
        </button>

        <ul class="dropdown-menu shadow">
          <li>
            <h6 class="dropdown-header">
              In <strong><%= current_workspace.name %></strong>
            </h6>
          </li>
          <% other_workspaces = current_user.workspaces.where.not(id: current_workspace.id).order(:name) %>
          <% if other_workspaces.any? %>
            <li><hr class="dropdown-divider"></li>
            <li><h6 class="dropdown-header">Switch to</h6></li>
            <% other_workspaces.each do |ws| %>
              <li>
                <%= button_to switch_workspace_path(ws),
                              method: :post,
                              class: "dropdown-item",
                              form: { class: "d-inline w-100" } do %>
                  <i class="bi bi-box-arrow-right me-2"></i><%= ws.name %>
                <% end %>
              </li>
            <% end %>
          <% end %>
          <li><hr class="dropdown-divider"></li>
          <li>
            <%= link_to new_workspace_path, class: "dropdown-item" do %>
              <i class="bi bi-plus-circle me-2"></i>Create new workspace
            <% end %>
          </li>
        </ul>
      </div>
    <% end %>

    <%# ─── Primary nav ────────────────────────────────────────── %>
    <div class="fv-sidebar-nav">
      <%= link_to authenticated_root_path,
          class: "fv-nav-item #{'active' if current_page?(authenticated_root_path) || current_page?(folders_path)}" do %>
        <i class="bi bi-grid-1x2 fv-nav-icon"></i>
        <span class="fv-nav-label">Dashboard</span>
      <% end %>

      <%= link_to folders_path,
          class: "fv-nav-item #{'active' if controller_name == 'folders' && action_name != 'index'}" do %>
        <i class="bi bi-folder fv-nav-icon"></i>
        <span class="fv-nav-label">Folders</span>
      <% end %>

      <%= link_to recent_activities_path,
          class: "fv-nav-item #{'active' if current_page?(recent_activities_path)}" do %>
        <i class="bi bi-clock-history fv-nav-icon"></i>
        <span class="fv-nav-label">Recent</span>
      <% end %>

      <%= link_to pins_path,
          class: "fv-nav-item #{'active' if current_page?(pins_path)}" do %>
        <i class="bi bi-pin-angle fv-nav-icon"></i>
        <span class="fv-nav-label">Pinned</span>
      <% end %>

      <%= link_to team_path,
          class: "fv-nav-item #{'active' if current_page?(team_path)}" do %>
        <i class="bi bi-people fv-nav-icon"></i>
        <span class="fv-nav-label">Team</span>
      <% end %>

      <%= link_to workspace_path,
          class: "fv-nav-item #{'active' if current_page?(workspace_path)}" do %>
        <i class="bi bi-sliders fv-nav-icon"></i>
        <span class="fv-nav-label">Workspace settings</span>
      <% end %>
    </div>

    <%# ─── User section at bottom ─────────────────────────────── %>
    <div class="fv-sidebar-user dropend">
      <button class="fv-user-trigger"
              type="button"
              data-bs-toggle="dropdown"
              aria-expanded="false">
        <div class="fv-user-avatar">
          <%= display_name(current_user).first.upcase %>
        </div>
        <div class="fv-user-meta">
          <div class="fv-user-email"><%= current_user.email %></div>
        </div>
        <i class="bi bi-three-dots-vertical fv-user-caret"></i>
      </button>

      <ul class="dropdown-menu shadow">
        <li>
          <h6 class="dropdown-header"><%= current_user.email %></h6>
        </li>
        <li><hr class="dropdown-divider"></li>
        <li>
          <%= button_to destroy_user_session_path,
                        method: :delete,
                        class: "dropdown-item",
                        form: { class: "d-inline w-100" } do %>
            <i class="bi bi-box-arrow-left me-2"></i>Sign out
          <% end %>
        </li>
      </ul>
    </div>

  </nav>
<% end %>
