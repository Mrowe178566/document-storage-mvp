<div class="fv-auth-wrapper">
  <div class="fv-auth-card">

    <div class="fv-auth-logo">
      <%= image_tag "vault-logo.png", alt: "File Vault", width: 48, height: 48 %>
    </div>

    <h1 class="fv-auth-title">Welcome back</h1>
    <p class="fv-auth-subtitle">Sign in to your File Vault workspace</p>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="fv-form-group">
        <%= f.input :email,
            required: false,
            autofocus: true,
            label: "Email address",
            input_html: {
              autocomplete: "email",
              class: "fv-input"
            },
            label_html: { class: "fv-label" },
            wrapper_html: { class: "fv-field" } %>
      </div>

      <div class="fv-form-group">
        <%= f.input :password,
            required: false,
            input_html: {
              autocomplete: "current-password",
              class: "fv-input"
            },
            label_html: { class: "fv-label" },
            wrapper_html: { class: "fv-field" } %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="fv-remember">
          <%= f.input :remember_me, as: :boolean, label: "Remember me" %>
        </div>
      <% end %>

      <%= f.button :submit, "Sign in", class: "fv-btn-primary w-100 mt-3" %>
    <% end %>

    <div class="fv-auth-links">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
