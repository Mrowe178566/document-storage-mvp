<div class="container py-4">

  <header class="mb-4">
    <h1 class="fw-bold mb-1">Pinned</h1>
    <p class="text-muted mb-0">
      Quick access to the folders you work in most.
    </p>
  </header>

  <div class="card border-0 fv-card">
    <div class="card-body text-center py-5 px-4">
      <svg width="120" height="100" viewBox="0 0 120 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="mb-3">
        <rect x="20" y="30" width="80" height="50" rx="6" fill="#f1f3f5"/>
        <rect x="20" y="30" width="80" height="10" rx="6" fill="#dee2e6"/>
        <path d="M88 22 L92 18 L96 22 L96 32 L92 36 L88 32 Z" fill="#fbbf24"/>
        <circle cx="92" cy="26" r="2" fill="#fff"/>
      </svg>
      <h2 class="h5 fw-bold mb-2">No pinned folders yet</h2>
      <p class="text-muted mb-3 mx-auto" style="max-width: 420px;">
        Pin folders to keep them one click away. Each teammate has their own pins —
        what you pin only shows up for you.
      </p>
      <%= link_to folders_path, class: "btn btn-outline-primary" do %>
        <i class="bi bi-folder me-1"></i>Browse folders
      <% end %>
    </div>
  </div>

</div>
