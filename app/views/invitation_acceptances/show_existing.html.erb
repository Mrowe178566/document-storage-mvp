<div class="container py-5" style="max-width: 480px;">

  <h1 class="fw-bold mb-2">Join <%= @invitation.workspace.name %>?</h1>
  <p class="text-muted mb-4">
    <strong><%= @invitation.invited_by.email %></strong> invited you to join
    <strong><%= @invitation.workspace.name %></strong> on File Vault.
    You're already signed in as <strong><%= current_user.email %></strong>.
  </p>

  <%= form_with url: invitation_acceptance_path(token: @invitation.token), method: :patch, local: true do |form| %>
    <%= form.submit "Join workspace", class: "btn btn-primary w-100" %>
  <% end %>

  <div class="text-center mt-3">
    <%= link_to "Not now", authenticated_root_path, class: "text-muted small" %>
  </div>

</div>
