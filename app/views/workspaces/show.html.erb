<div class="container py-4">

  <header class="mb-4">
    <h1 class="fw-bold mb-1"><%= @workspace.name %></h1>
    <p class="text-muted mb-0">Workspace settings, members, and pending invitations.</p>
  </header>

  <% if policy(@workspace).update? %>
    <section class="card mb-4">
      <div class="card-body">
        <h2 class="h5 fw-semibold mb-3">Workspace name</h2>
        <%= form_with model: @workspace, url: workspace_path, method: :patch, local: true, class: "d-flex gap-2" do |form| %>
          <%= form.text_field :name, class: "form-control", required: true %>
          <%= form.submit "Save", class: "btn btn-primary" %>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="card mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 fw-semibold mb-0">Members</h2>
        <% if policy(Invitation.new(workspace: @workspace)).create? %>
          <%= link_to "Invite member", new_workspace_invitation_path, class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>

      <ul class="list-group">
        <% @memberships.each do |membership| %>
          <% role_badge_class = { "owner" => "warning", "admin" => "primary", "member" => "secondary", "viewer" => "info" }[membership.role] %>
          <li class="list-group-item">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
              <div>
                <div class="fw-semibold"><%= membership.user.email %></div>
                <div class="d-flex gap-2 align-items-center mt-1">
                  <span class="badge text-bg-<%= role_badge_class %> text-uppercase">
                    <%= membership.role %>
                  </span>
                  <% if membership.user == current_user %>
                    <span class="badge text-bg-light">You</span>
                  <% end %>
                </div>
              </div>

              <div class="d-flex gap-1 flex-wrap">
                <%# Promote (admin can promote member → admin; also covers viewer → admin) %>
                <% if policy(membership).update? && !membership.role.in?(%w[admin owner]) %>
                  <%= button_to "Make admin",
                                workspace_membership_path(membership, role: "admin"),
                                method: :patch,
                                class: "btn btn-sm btn-outline-secondary",
                                form: { data: { turbo_confirm: "Promote #{membership.user.email} to admin?" } } %>
                <% end %>

                <%# Demote (admin → member) %>
                <% if policy(membership).update? && membership.role == "admin" %>
                  <%= button_to "Demote",
                                workspace_membership_path(membership, role: "member"),
                                method: :patch,
                                class: "btn btn-sm btn-outline-secondary",
                                form: { data: { turbo_confirm: "Demote #{membership.user.email} to member?" } } %>
                <% end %>

                <%# Transfer ownership (owner only, target is admin and not self) %>
                <% if policy(membership).transfer? && membership.user != current_user %>
                  <%= button_to "Transfer ownership",
                                workspace_membership_path(membership, role: "owner"),
                                method: :patch,
                                class: "btn btn-sm btn-outline-warning",
                                form: { data: { turbo_confirm: "Transfer ownership of this workspace to #{membership.user.email}? You'll be demoted to admin." } } %>
                <% end %>

                <%# Remove (admin only, target is not owner and not self) %>
                <% if policy(membership).destroy? && membership.user != current_user %>
                  <%= button_to "Remove",
                                workspace_membership_path(membership),
                                method: :delete,
                                class: "btn btn-sm btn-outline-danger",
                                form: { data: { turbo_confirm: "Remove #{membership.user.email} from #{@workspace.name}?" } } %>
                <% end %>

                <%# Leave (self, not owner) %>
                <% if membership.user == current_user && policy(membership).leave? %>
                  <%= button_to "Leave workspace",
                                workspace_membership_path(membership),
                                method: :delete,
                                class: "btn btn-sm btn-outline-danger",
                                form: { data: { turbo_confirm: "Leave #{@workspace.name}? You'll lose access to its folders and files." } } %>
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </section>

  <% if @pending_invitations.any? %>
    <section class="card">
      <div class="card-body">
        <h2 class="h5 fw-semibold mb-1">Pending invitations</h2>
        <p class="text-muted small mb-3">
          Invitees receive an email automatically. You can also share the accept link manually if email delivery is delayed.
        </p>
        <ul class="list-group">
          <% @pending_invitations.each do |invitation| %>
            <li class="list-group-item">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                  <div class="fw-semibold"><%= invitation.email %></div>
                  <small class="text-muted">
                    Sent by <%= invitation.invited_by.email %> ·
                    expires <%= time_ago_in_words(invitation.expires_at, include_seconds: false) %> from now
                  </small>
                </div>
              </div>
              <div data-controller="clipboard" class="input-group input-group-sm">
                <input type="text"
                       readonly
                       value="<%= invitation_acceptance_url(token: invitation.token) %>"
                       class="form-control font-monospace"
                       data-clipboard-target="source"
                       onclick="this.select()">
                <button class="btn btn-outline-secondary"
                        type="button"
                        data-action="click->clipboard#copy"
                        data-clipboard-target="button">
                  Copy link
                </button>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    </section>
  <% end %>

</div>
