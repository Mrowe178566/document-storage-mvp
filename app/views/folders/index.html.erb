<div class="container py-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Your Folders</h2>

    <%= link_to "New Folder",
        new_folder_path,
        class: "btn btn-primary fancy-button" %>
  </div>

  <div class="list-group shadow-sm">
    <% @folders.each do |folder| %>
      <div class="list-group-item d-flex justify-content-between align-items-center">

        <div class="d-flex align-items-center gap-2">
          <i class="bi bi-folder-fill text-warning" style="font-size: 1.3rem;"></i>
          <%= link_to folder.name,
              folder_path(folder),
              class: "fw-semibold text-decoration-none" %>
        </div>

        <div class="d-flex gap-2">

          <%= link_to "Open",
              folder_path(folder),
              class: "btn btn-sm btn-outline-primary" %>

          <%= link_to "Edit",
              edit_folder_path(folder),
              class: "btn btn-sm btn-secondary" %>

          <button class="btn btn-sm btn-danger"
                  onclick="confirmDelete('<%= folder_path(folder) %>')">
            Delete
          </button>

        </div>

      </div>
    <% end %>
  </div>

</div>

<%= render "shared/delete_modal" %>
