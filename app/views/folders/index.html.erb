<div data-controller="modal" class="container py-4">

  <%# ============================================================
      Workspace header
      Name, role badge, and metadata pills (folders / files / members)
      ============================================================ %>
  <header class="mb-4">
    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
      <h1 class="fw-bold mb-0 me-2"><%= current_workspace.name %></h1>
      <% if @dashboard[:role] %>
        <% role_badge = { "owner" => "warning", "admin" => "primary", "member" => "secondary", "viewer" => "info" }[@dashboard[:role]] %>
        <span class="badge text-bg-<%= role_badge %> text-uppercase">
          <%= @dashboard[:role] %>
        </span>
      <% end %>
    </div>
    <p class="text-muted mb-3">
      Welcome back, <%= display_name(current_user) %>. Here's what's happening in your workspace.
    </p>

    <div class="d-flex flex-wrap gap-3 small text-muted">
      <span><i class="bi bi-folder-fill text-warning me-1"></i><strong class="text-dark"><%= @dashboard[:folder_count] %></strong> <%= "folder".pluralize(@dashboard[:folder_count]) %></span>
      <span><i class="bi bi-file-earmark text-primary me-1"></i><strong class="text-dark"><%= @dashboard[:file_count] %></strong> <%= "file".pluralize(@dashboard[:file_count]) %></span>
      <span><i class="bi bi-people text-success me-1"></i><strong class="text-dark"><%= @dashboard[:member_count] %></strong> <%= "member".pluralize(@dashboard[:member_count]) %></span>
    </div>
  </header>

  <%# ============================================================
      Quick actions row — buttons appear only for users with permission
      ============================================================ %>
  <div class="d-flex flex-wrap gap-2 mb-4">
    <% if policy(Folder.new(workspace: current_workspace)).create? %>
      <%= link_to new_folder_path, class: "btn btn-primary" do %>
        <i class="bi bi-folder-plus me-1"></i>New folder
      <% end %>
    <% end %>
    <% if policy(Invitation.new(workspace: current_workspace)).create? %>
      <%= link_to new_workspace_invitation_path, class: "btn btn-outline-primary" do %>
        <i class="bi bi-person-plus me-1"></i>Invite teammate
      <% end %>
    <% end %>
    <%= link_to workspace_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-sliders me-1"></i>Workspace settings
    <% end %>
  </div>

  <% if @folders.empty? %>
    <%# ============================================================
        Empty state — richer illustration + bootstrap CTA
        ============================================================ %>
    <div class="card shadow-sm border-0">
      <div class="card-body text-center py-5 px-4">
        <%# Inline SVG illustration — no extra asset required %>
        <svg width="180" height="140" viewBox="0 0 180 140" fill="none" xmlns="http://www.w3.org/2000/svg" class="mb-3">
          <rect x="20" y="40" width="140" height="80" rx="8" fill="#f1f3f5"/>
          <rect x="20" y="40" width="140" height="16" rx="8" fill="#dee2e6"/>
          <rect x="30" y="68" width="60" height="8" rx="4" fill="#ced4da"/>
          <rect x="30" y="82" width="90" height="8" rx="4" fill="#e9ecef"/>
          <rect x="30" y="96" width="70" height="8" rx="4" fill="#e9ecef"/>
          <circle cx="140" cy="100" r="22" fill="#ffd43b"/>
          <path d="M130 100 L138 108 L152 92" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
        <h2 class="h4 fw-bold mb-2">Your workspace is empty</h2>
        <p class="text-muted mb-4 mx-auto" style="max-width: 460px;">
          <% if policy(current_workspace).bootstrap? %>
            Get started fast with our manufacturing template — six pre-built folders covering quality control, production, compliance, and more.
          <% else %>
            No folders here yet. An admin can add some.
          <% end %>
        </p>
        <div class="d-flex flex-wrap gap-2 justify-content-center">
          <% if policy(current_workspace).bootstrap? %>
            <%= button_to bootstrap_workspace_path,
                          method: :post,
                          class: "btn btn-primary btn-lg" do %>
              <i class="bi bi-magic me-1"></i>Create Starter Structure
            <% end %>
          <% end %>
          <% if policy(Folder.new(workspace: current_workspace)).create? %>
            <%= link_to new_folder_path, class: "btn btn-outline-secondary btn-lg" do %>
              Start blank
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <%# ============================================================
        Two-column: Suggested folders + Recent activity
        ============================================================ %>
    <div class="row g-4 mb-4">
      <div class="col-lg-7">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h2 class="h6 text-uppercase text-muted fw-semibold mb-3">
              <i class="bi bi-stars me-1"></i>Suggested for you
            </h2>
            <% if @dashboard[:suggested_folders].any? %>
              <div class="row g-2">
                <% @dashboard[:suggested_folders].each do |folder| %>
                  <div class="col-sm-6">
                    <%= link_to folder_path(folder),
                                class: "d-flex align-items-center gap-2 p-2 rounded text-decoration-none text-dark border" do %>
                      <i class="bi bi-folder-fill text-warning fs-4"></i>
                      <div class="overflow-hidden">
                        <div class="fw-semibold text-truncate"><%= folder.name %></div>
                        <div class="small text-muted">
                          <%= folder.stored_files.size %> <%= "file".pluralize(folder.stored_files.size) %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted small mb-0">Nothing to suggest yet — upload a file to a folder to see it here.</p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="col-lg-5">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h2 class="h6 text-uppercase text-muted fw-semibold mb-3">
              <i class="bi bi-clock-history me-1"></i>Recent activity
            </h2>
            <% if @dashboard[:recent_activity].any? %>
              <ul class="list-unstyled mb-0">
                <% @dashboard[:recent_activity].first(6).each do |event| %>
                  <li class="d-flex gap-2 align-items-start mb-3">
                    <i class="bi <%= event.icon %> text-muted mt-1"></i>
                    <div class="small">
                      <div>
                        <strong><%= event.actor_email&.split("@")&.first || "Someone" %></strong>
                        <%= sanitize event.message, tags: %w[strong em] %>
                      </div>
                      <div class="text-muted">
                        <%= time_ago_in_words(event.timestamp) %> ago
                      </div>
                    </div>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-muted small mb-0">No activity yet.</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%# ============================================================
        All folders grid
        ============================================================ %>
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="h5 fw-semibold mb-0">All folders</h2>
    </div>

    <div class="row g-4">
      <% @folders.each do |folder| %>
        <div class="col-md-4">
          <div class="card shadow-sm h-100 border-0">
            <div class="card-body d-flex flex-column">
              <div class="d-flex align-items-center mb-3">
                <i class="bi bi-folder-fill text-warning me-3 folder-icon"></i>
                <div class="overflow-hidden">
                  <h5 class="card-title mb-1 text-truncate">
                    <%= link_to folder.name, folder_path(folder), class: "text-decoration-none text-dark fw-semibold" %>
                    <% if folder.restricted? %>
                      <i class="bi bi-lock-fill text-muted small ms-1"
                         title="Restricted folder — limited access"></i>
                    <% end %>
                  </h5>
                  <p class="text-muted small mb-0">
                    Updated <%= time_ago_in_words(folder.updated_at) %> ago
                  </p>
                </div>
              </div>
              <div class="d-flex gap-2 mt-auto">
                <%= link_to "Open", folder_path(folder), class: "btn btn-outline-primary btn-sm" %>
                <% if policy(folder).edit? %>
                  <%= link_to "Edit", edit_folder_path(folder), class: "btn btn-outline-secondary btn-sm" %>
                <% end %>
                <% if policy(folder).destroy? %>
                  <button class="btn btn-outline-danger btn-sm"
                          data-action="click->modal#open"
                          data-url="<%= folder_path(folder) %>"
                          data-name="<%= folder.name %>">
                    Delete
                  </button>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# ============================================================
      Delete Confirmation Modal (unchanged)
      ============================================================ %>
  <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header border-0">
          <h5 class="modal-title fw-bold text-danger" id="deleteModalLabel">
            <i class="bi bi-exclamation-triangle me-2"></i>Delete Folder
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>You are about to delete <strong data-modal-target="folderName"></strong>.</p>
          <p class="text-danger fw-semibold mb-0">This will permanently delete the folder and all files inside it. This cannot be undone.</p>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <%= form_with url: "#", method: :delete, local: true, data: { modal_target: "form" } do |f| %>
            <%= f.submit "Yes, delete permanently", class: "btn btn-danger" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

</div>
