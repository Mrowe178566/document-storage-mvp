<header class="mb-4">
  <h1 class="fw-bold">Welcome back, <%= display_name(current_user) %> 👋</h1>
  <p class="text-muted">Here are your folders.</p>
</header>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="h4 fw-semibold">Your Folders</h2>
  <%= link_to "New Folder", new_folder_path, class: "btn btn-primary" %>
</div>

<% if @folders.empty? %>
  <div class="text-center text-muted py-5">
    <i class="bi bi-folder-x folder-icon"></i>
    <p class="mt-3">No folders yet. Create your first one!</p>
  </div>
<% else %>
  <div class="row g-4">
    <% @folders.each do |folder| %>
      <div class="col-md-4">
        <div class="card shadow-sm h-100">
          <div class="card-body d-flex flex-column">
            <div class="d-flex align-items-center mb-3">
              <i class="bi bi-folder-fill text-warning me-3 folder-icon"></i>
              <div>
                <h5 class="card-title mb-1">
                  <%= link_to folder.name, folder_path(folder), class: "text-decoration-none text-dark fw-semibold" %>
                </h5>
                <p class="text-muted small mb-0">
                  Updated <%= time_ago_in_words(folder.updated_at) %> ago
                </p>
              </div>
            </div>
            <div class="d-flex gap-2 mt-auto">
              <%= link_to "Open", folder_path(folder), class: "btn btn-outline-primary btn-sm" %>
              <%= link_to "Edit", edit_folder_path(folder), class: "btn btn-outline-secondary btn-sm" %>
              <%= button_to "Delete", folder_path(folder), method: :delete,
                  class: "btn btn-outline-danger btn-sm",
                  form: { data: { turbo_confirm: "Delete '#{folder.name}' and all its files? This cannot be undone." } } %>
              
    
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
