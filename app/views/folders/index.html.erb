<div data-controller="modal">

  <header class="mb-4">
    <h1 class="fw-bold">Welcome back, <%= display_name(current_user) %> 👋</h1>
    <p class="text-muted">Here are your folders.</p>
  </header>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 fw-semibold">Your Folders</h2>
    <%= link_to "New Folder", new_folder_path, class: "btn btn-primary" %>
  </div>

  <% if @folders.empty? %>
    <div class="text-center text-muted py-5">
      <i class="bi bi-folder-x folder-icon"></i>
      <p class="mt-3">No folders yet. Create your first one!</p>
    </div>
  <% else %>
    <div class="row g-4">
      <% @folders.each do |folder| %>
        <div class="col-md-4">
          <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
              <div class="d-flex align-items-center mb-3">
                <i class="bi bi-folder-fill text-warning me-3 folder-icon"></i>
                <div>
                  <h5 class="card-title mb-1">
                    <%= link_to folder.name, folder_path(folder), class: "text-decoration-none text-dark fw-semibold" %>
                  </h5>
                  <p class="text-muted small mb-0">
                    Updated <%= time_ago_in_words(folder.updated_at) %> ago
                  </p>
                </div>
              </div>
              <div class="d-flex gap-2 mt-auto">
                <%= link_to "Open", folder_path(folder), class: "btn btn-outline-primary btn-sm" %>
                <%= link_to "Edit", edit_folder_path(folder), class: "btn btn-outline-secondary btn-sm" %>
                <button class="btn btn-outline-danger btn-sm"
                        data-action="click->modal#open"
                        data-url="<%= folder_path(folder) %>"
                        data-name="<%= folder.name %>">
                  Delete
                </button>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Delete Confirmation Modal -->
  <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header border-0">
          <h5 class="modal-title fw-bold text-danger" id="deleteModalLabel">
            <i class="bi bi-exclamation-triangle me-2"></i>Delete Folder
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>You are about to delete <strong data-modal-target="folderName"></strong>.</p>
          <p class="text-danger fw-semibold mb-0">This will permanently delete the folder and all files inside it. This cannot be undone.</p>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <%= form_with url: "#", method: :delete, local: true, data: { modal_target: "form" } do |f| %>
            <%= f.submit "Yes, delete permanently", class: "btn btn-danger" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

</div>
