<div class="container py-4">

  <!-- Folder Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold mb-0">
      <i class="bi bi-folder-fill text-warning me-2"></i><%= @folder.name %>
    </h1>
  </div>

  <!-- Upload Form -->
  <div class="mb-4">
    <h5 class="fw-semibold mb-3">Upload a File</h5>
    <%= render "stored_files/form", folder: @folder, stored_file: StoredFile.new %>
  </div>

  <!-- Search Bar -->
  <div class="mb-4">
    <%= form_with url: folder_path(@folder), method: :get, class: "d-flex gap-2" do |form| %>
      <%= form.text_field :query, value: params[:query],
          class: "form-control", placeholder: "Search files..." %>
      <%= form.submit "Search", class: "btn btn-outline-primary" %>
    <% end %>
  </div>

  <!-- Files List -->
  <% if @files.empty? %>
    <div class="text-center text-muted py-5">
      <i class="bi bi-file-earmark-x" style="font-size: 3rem;"></i>
      <p class="mt-3">No files yet. Upload your first one!</p>
    </div>
  <% else %>
    <%= form_with url: bulk_delete_stored_files_path, method: :delete, local: true do |form| %>
      <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="form-check" data-controller="select-all">
          <input type="checkbox" class="form-check-input"
                 data-select-all-target="selectAll"
                 data-action="change->select-all#toggle">
          <label class="form-check-label">Select all</label>
        </div>
        <%= form.submit "Delete Selected", class: "btn btn-outline-danger btn-sm" %>
      </div>

      <div class="list-group">
        <% @files.each do |file| %>
          <div class="list-group-item d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
              <input type="checkbox" class="form-check-input file-checkbox"
                     data-select-all-target="checkbox"
                     name="file_ids[]" value="<%= file.id %>">
              <i class="bi bi-file-earmark text-primary"></i>
              <span><%= file.file_name %></span>
            </div>
            <div class="d-flex gap-2">
              <%= link_to "Download", rails_blob_path(file.uploaded_file, disposition: "attachment"),
                  class: "btn btn-outline-secondary btn-sm" %>
              <%= button_to "Delete", stored_file_path(file), method: :delete,
                  class: "btn btn-outline-danger btn-sm",
                  form: { data: { turbo_confirm: "Delete '#{file.file_name}'? This cannot be undone." } } %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>

</div>
