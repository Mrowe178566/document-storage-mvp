<%= render "shared/breadcrumbs" %>

<h1 class="mb-4"><%= @folder.name %></h1>

<!-- List stored files -->
<% if @folder.stored_files.any? %>
  <% @folder.stored_files.each do |stored_file| %>
    <div class="d-flex justify-content-between align-items-center mb-3 p-2 border rounded">
      <div>
        <%= link_to stored_file.file_name, stored_file_path(stored_file), class: "fw-semibold" %>
      </div>

      <div class="d-flex gap-2">
        <%= link_to "Download",
              rails_blob_path(stored_file.uploaded_file, disposition: "attachment"),
              class: "btn btn-sm btn-outline-primary" %>

        <%= button_to "Delete",
              stored_file_path(stored_file),
              method: :delete,
              data: { confirm: "Are you sure?" },
              class: "btn btn-sm btn-outline-danger" %>
      </div>
    </div>
  <% end %>
<% else %>
  <p class="text-muted fst-italic">No files uploaded yet.</p>
<% end %>

<!-- Upload new file -->
<div class="mt-4">
  <%= render "stored_files/form", folder: @folder %>
</div>
