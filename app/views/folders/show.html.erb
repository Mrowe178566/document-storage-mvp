<%= form_with url: folder_path(@folder), method: :get, local: true do %>
  <%= text_field_tag :query, params[:query], placeholder: "Search files..." %>
  <%= submit_tag "Search",
      class: "btn",
      style: "background-color: #000; color: #fff; padding: 0.45rem 1rem; border-radius: 6px; font-weight: 600;" %>
<% end %>

<div class="container py-4">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold mb-0"><%= @folder.name %></h2>

    <%= link_to "Back to Dashboard",
        folders_path,
        class: "contrast outline",
        style: "padding: 0.4rem 1rem;" %>
  </div>

  <hr>

  <!-- Bulk Delete Form -->
  <%= form_with url: bulk_delete_stored_files_path, method: :delete, local: true do %>

    <!-- Select All -->
    <div class="form-check mb-3">
      <%= check_box_tag "select_all", "", false, id: "select_all", class: "form-check-input" %>
      <label class="form-check-label" for="select_all">Select All</label>
    </div>

    <!-- File List -->
    <div class="list-group mb-4 shadow-sm">
      <% @files.each do |file| %>
        <div class="list-group-item d-flex justify-content-between align-items-center">

          <div class="d-flex align-items-center">
            <%= check_box_tag "file_ids[]", file.id, false, class: "form-check-input me-2 file-checkbox" %>

            <strong>
              <% if file.uploaded_file.attached? %>
                <%= file.uploaded_file.filename %>
              <% else %>
                <%= file.file_name %>
              <% end %>
            </strong>
          </div>

          <% if file.uploaded_file.attached? %>
            <%= link_to "Download",
                rails_blob_path(file.uploaded_file, disposition: "attachment"),
                class: "btn btn-sm btn-outline-primary" %>
          <% end %>

        </div>
      <% end %>
    </div>

    <!-- Delete Button -->
    <%# You should add a confirmation dialog before deleting files just like you have a check for deleting folders %>
    <%= submit_tag "Delete Selected",
        class: "btn btn-danger",
        style: "padding: 0.4rem 1rem;" %>

  <% end %>

  <hr class="my-4">

  <!-- Upload Form Partial -->
  <%= render "stored_files/form", folder: @folder %>

</div>

<%# Raw JS here is not something that should be used in a production environment whenever you are making website mechanics if you want it to be reused you should create a separate JavaScript file and reference that file %>
<!-- Select All Script -->
<script>
  document.addEventListener("turbo:load", () => {
    const selectAll = document.getElementById("select_all");
    const checkboxes = document.querySelectorAll(".file-checkbox");

    selectAll.addEventListener("change", () => {
      checkboxes.forEach(cb => cb.checked = selectAll.checked);
    });
  });
</script>
